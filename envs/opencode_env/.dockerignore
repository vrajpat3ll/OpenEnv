# Don't bloat the build context. Copy only what the runtime needs.
.venv
__pycache__
**/__pycache__
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.ruff_cache

# NEVER ship secrets into the image. The container reads E2B_API_KEY etc.
# from runtime env vars (HF Space secrets, ``docker run -e``).
.env
.env.*

# Test artifacts and local debug output.
tests/_artifacts/
*.log
.coverage
htmlcov/

# Editor / IDE noise.
.idea
.vscode
.DS_Store

# Git metadata is unused at runtime.
.git
.gitignore
